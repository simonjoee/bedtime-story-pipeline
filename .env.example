# ModelScope (Qwen-Image-2512) Image Generation
MODELSCOPE_API_KEY=

# ZhipuAI (智谱AI) - 用于故事润色
ZHIPU_API_KEY=

# MiniMax TTS
MINIMAX_ACCESS_TOKEN=

# YouTube OAuth
CLIENT_SECRETS_FILE=client_secrets.json

# Demo Mode: true=跳过AI生成，仅验证UI流程；false=正常生成视频
DEMO_MODE=false

# 是否需要登录 (true/false)
REQUIRE_LOGIN=true

# Auth
ADMIN_PASSWORD=
SESSION_SECRET=your-secret-key-change-this

# Base Path (如 /bs,留空则为根路径)
BASE_PATH=
